import os
import kagglehub
import pandas as pd
import matplotlib.pyplot as plt

# Download Air Passengers dataset
path = kagglehub.dataset_download("rakannimer/air-passengers")

# Load dataset
df = pd.read_csv(os.path.join(path, "AirPassengers.csv"))

# Convert date column
df['Month'] = pd.to_datetime(df['Month'])
df.set_index('Month', inplace=True)

# Select time series column
ts = df['#Passengers']

# Moving Average
moving_avg = ts.rolling(window=12).mean()

# Plot
plt.figure(figsize=(10,5))
plt.plot(ts, label='Original Data')
plt.plot(moving_avg, label='12-Month Moving Average', linewidth=3)
plt.title('Moving Average Time Series Analysis')
plt.legend()
plt.show()
